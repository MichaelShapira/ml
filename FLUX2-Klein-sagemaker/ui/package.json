{
  "name": "ai-photo-booth-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "AI Photo Booth kiosk SPA (Vite + React + TypeScript)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
