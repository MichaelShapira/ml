    "@aws-sdk/credential-providers": "^3.687.0",
    "@aws-sdk/lib-dynamodb": "^3.687.0",
    "@aws-sdk/types": "^3.687.0",
    "@smithy/protocol-http": "^4.1.8",
    "@smithy/signature-v4": "^5.4.6",
